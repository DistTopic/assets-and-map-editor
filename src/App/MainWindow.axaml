<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:POriginsItemEditor.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="POriginsItemEditor.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="POrigins Item Editor"
        Width="1320" Height="780"
        MinWidth="1000" MinHeight="600"
        Background="#1e1e2e">

  <Window.Styles>
    <!-- Accent colors -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#89b4fa"/>
      <Setter Property="Foreground" Value="#1e1e2e"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#74c7ec"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#f38ba8"/>
      <Setter Property="Foreground" Value="#1e1e2e"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.toolbar">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="Medium"/>
    </Style>
    <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#45475a"/>
    </Style>
    <Style Selector="Button.client">
      <Setter Property="Background" Value="#a6e3a1"/>
      <Setter Property="Foreground" Value="#1e1e2e"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.client:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#94e2d5"/>
    </Style>

    <!-- ListBox -->
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#313244"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#262637"/>
    </Style>

    <!-- TextBox styling -->
    <Style Selector="TextBox.search">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="BorderBrush" Value="#45475a"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBox.search:focus /template/ Border">
      <Setter Property="BorderBrush" Value="#89b4fa"/>
    </Style>

    <!-- Panel styling -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#181825"/>
      <Setter Property="BorderBrush" Value="#313244"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14"/>
    </Style>

    <Style Selector="TextBlock.heading">
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#a6adc8"/>
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Margin" Value="0,2"/>
    </Style>

    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="#313244"/>
      <Setter Property="Foreground" Value="#cdd6f4"/>
      <Setter Property="BorderBrush" Value="#45475a"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinWidth" Value="70"/>
    </Style>

    <!-- Mismatch badge -->
    <Style Selector="Border.mismatch-badge">
      <Setter Property="Background" Value="#f38ba8"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>
    <Style Selector="Border.ok-badge">
      <Setter Property="Background" Value="#a6e3a1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- ═══ Top Toolbar ═══ -->
    <Border DockPanel.Dock="Top" Background="#11111b" Padding="16,10">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="⚙" FontSize="22" VerticalAlignment="Center" Foreground="#89b4fa" Margin="0,0,6,0"/>
          <TextBlock Text="POrigins Item Editor" FontSize="16" FontWeight="Bold"
                     Foreground="#cdd6f4" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button Classes="client" Command="{Binding SelectClientFolderCommand}" Content="📁 Selecionar Client"/>
          <Button Classes="toolbar" Command="{Binding OpenOtbCommand}" Content="📂 Abrir OTB"/>
          <Button Classes="accent" Command="{Binding SaveOtbCommand}" Content="💾 Salvar"/>
          <Button Classes="toolbar" Command="{Binding SaveOtbAsCommand}" Content="Salvar Como..."/>
        </StackPanel>

        <!-- Stats -->
        <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Total:" Classes="label" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TotalItems}" Foreground="#89b4fa" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Filtrados:" Classes="label" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding FilteredCount}" Foreground="#a6e3a1" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="Mismatches:" Classes="label" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding MismatchCount}" Foreground="#f38ba8" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock IsVisible="{Binding IsClientLoaded}" Text="✓ Client" Foreground="#a6e3a1"
                     FontWeight="Bold" VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ═══ Status bar ═══ -->
    <Border DockPanel.Dock="Bottom" Background="#11111b" Padding="16,6">
      <DockPanel>
        <TextBlock Text="{Binding StatusText}" Foreground="#a6adc8" FontSize="12" VerticalAlignment="Center"/>
        <TextBlock DockPanel.Dock="Right" IsVisible="{Binding HasUnsavedChanges}"
                   Text="● Modificado" Foreground="#fab387" FontSize="12" FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- ═══ Main Content ═══ -->
    <Grid ColumnDefinitions="*,420" Margin="12,10">
      <!-- ─── Left: Search + List ─── -->
      <DockPanel Grid.Column="0" Margin="0,0,10,0">
        <!-- Search bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" Margin="10,0,0,0">
            <CheckBox Content="Só Deprecated" IsChecked="{Binding ShowDeprecatedOnly}"
                      VerticalAlignment="Center"/>
            <CheckBox Content="Só mismatches" IsChecked="{Binding ShowMismatchesOnly}"
                      VerticalAlignment="Center"/>
            <Button Classes="danger" Command="{Binding FixAllMismatchesCommand}"
                    Content="⚡ Corrigir Todos" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBox Classes="search" Watermark="Buscar por Server ID, Client ID, grupo ou nome..."
                   Text="{Binding SearchText}"/>
        </DockPanel>

        <!-- Item list -->
        <ListBox ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 SelectionMode="Single"
                 Background="#181825"
                 BorderBrush="#313244"
                 BorderThickness="1"
                 Padding="0">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ItemViewModel">
              <Grid ColumnDefinitions="38,Auto,*,Auto" Height="38" Margin="4,1">
                <!-- Sprite -->
                <Border Background="#11111b" CornerRadius="4" Width="32" Height="32"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        ClipToBounds="True">
                  <Image Source="{Binding Sprite}" Width="32" Height="32"
                         RenderOptions.BitmapInterpolationMode="None"
                         Stretch="None"/>
                </Border>

                <!-- Server ID + Client ID -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" Width="65">
                  <TextBlock Text="{Binding ServerId}" Foreground="#89b4fa" FontWeight="Bold" FontSize="13"/>
                  <TextBlock Text="{Binding ClientId, StringFormat='cid: {0}'}" Foreground="#585b70" FontSize="10"/>
                </StackPanel>

                <!-- Name / Group -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0" Spacing="6">
                  <TextBlock Text="{Binding DisplayName}"
                             Foreground="#cdd6f4" FontSize="12"
                             TextTrimming="CharacterEllipsis"/>
                  <Border IsVisible="{Binding IsDeprecated}" Background="#585b70" CornerRadius="3" Padding="4,1">
                    <TextBlock Text="DEPRECATED" FontSize="8" Foreground="#a6adc8" FontWeight="Bold"/>
                  </Border>
                </StackPanel>

                <!-- Mismatch indicator -->
                <Border Grid.Column="3" IsVisible="{Binding HasMismatch}"
                        Background="#f38ba8" CornerRadius="3" Padding="6,2"
                        VerticalAlignment="Center" Margin="0,0,6,0">
                  <TextBlock Text="MISMATCH" FontSize="9" FontWeight="Bold" Foreground="#1e1e2e"/>
                </Border>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <!-- ─── Right: Detail Panel ─── -->
      <ScrollViewer Grid.Column="1">
        <StackPanel Spacing="10" IsVisible="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}">

          <!-- ══ Appearance Card (Sprite + Identity) ══ -->
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Classes="heading" Text="Appearance"/>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                <!-- Sprite preview -->
                <Border Grid.Column="0" Background="#11111b" CornerRadius="6"
                        Width="68" Height="68" Padding="2"
                        BorderBrush="#45475a" BorderThickness="1">
                  <Image Source="{Binding SelectedItem.Sprite}"
                         Width="64" Height="64"
                         RenderOptions.BitmapInterpolationMode="None"
                         Stretch="Uniform"
                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Identity fields -->
                <Grid Grid.Column="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="10" RowSpacing="5">
                  <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Server ID" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="0" Grid.Column="1" Classes="field" Text="{Binding SelectedItem.ServerId}" IsReadOnly="True" IsEnabled="False"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Client ID" VerticalAlignment="Center"/>
                  <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" Content="−" Padding="6,2" MinWidth="28" FontWeight="Bold"
                            Background="#313244" Foreground="#cdd6f4" CornerRadius="4,0,0,4"
                            Command="{Binding SelectedItem.DecrementClientIdCommand}"/>
                    <TextBox Grid.Column="1" Classes="field" Text="{Binding SelectedItem.ClientId}"
                             CornerRadius="0" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="+" Padding="6,2" MinWidth="28" FontWeight="Bold"
                            Background="#313244" Foreground="#cdd6f4" CornerRadius="0,4,4,0"
                            Command="{Binding SelectedItem.IncrementClientIdCommand}"/>
                  </Grid>

                  <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Name" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="2" Grid.Column="1" Classes="field" Text="{Binding SelectedItem.Name}"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Type" VerticalAlignment="Center"/>
                  <ComboBox Grid.Row="3" Grid.Column="1"
                            ItemsSource="{Binding GroupOptions}"
                            SelectedItem="{Binding SelectedItem.Group}"
                            FontSize="12" MinHeight="28" Padding="6,3"/>
                </Grid>
              </Grid>
            </StackPanel>
          </Border>

          <!-- ══ Flags Card (traditional OTServ names) ══ -->
          <Border Classes="card">
            <StackPanel Spacing="6">
              <TextBlock Classes="heading" Text="Attributes"/>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                    ColumnSpacing="8" RowSpacing="0">
                <CheckBox Grid.Row="0" Grid.Column="0" Content="Unpassable"       IsChecked="{Binding SelectedItem.IsBlockSolid}"/>
                <CheckBox Grid.Row="0" Grid.Column="1" Content="Has Elevation"    IsChecked="{Binding SelectedItem.IsHasHeight}"/>

                <CheckBox Grid.Row="1" Grid.Column="0" Content="Movable"          IsChecked="{Binding SelectedItem.IsMoveable}"/>
                <CheckBox Grid.Row="1" Grid.Column="1" Content="Ignore Look"      IsChecked="{Binding SelectedItem.IsLookThrough}"/>

                <CheckBox Grid.Row="2" Grid.Column="0" Content="Block Missiles"   IsChecked="{Binding SelectedItem.IsBlockProjectile}"/>
                <CheckBox Grid.Row="2" Grid.Column="1" Content="Readable"         IsChecked="{Binding SelectedItem.IsReadable}"/>

                <CheckBox Grid.Row="3" Grid.Column="0" Content="Block Pathfinder" IsChecked="{Binding SelectedItem.IsBlockPathFind}"/>
                <CheckBox Grid.Row="3" Grid.Column="1" Content="Full Ground"      IsChecked="{Binding SelectedItem.IsFullGround}"/>

                <CheckBox Grid.Row="4" Grid.Column="0" Content="Pickupable"       IsChecked="{Binding SelectedItem.IsPickupable}"/>
                <CheckBox Grid.Row="4" Grid.Column="1" Content="Stackable"        IsChecked="{Binding SelectedItem.IsStackable}"/>

                <CheckBox Grid.Row="5" Grid.Column="0" Content="Force Use"        IsChecked="{Binding SelectedItem.IsForceUse}"/>
                <CheckBox Grid.Row="5" Grid.Column="1" Content="Multi Use"        IsChecked="{Binding SelectedItem.IsUsable}"/>

                <CheckBox Grid.Row="6" Grid.Column="0" Content="Rotatable"        IsChecked="{Binding SelectedItem.IsRotatable}"/>
                <CheckBox Grid.Row="6" Grid.Column="1" Content="Hangable"         IsChecked="{Binding SelectedItem.IsHangable}"/>

                <CheckBox Grid.Row="7" Grid.Column="0" Content="Hook South"       IsChecked="{Binding SelectedItem.IsVertical}"/>
                <CheckBox Grid.Row="7" Grid.Column="1" Content="Hook East"        IsChecked="{Binding SelectedItem.IsHorizontal}"/>

                <CheckBox Grid.Row="8" Grid.Column="0" Content="Animation"        IsChecked="{Binding SelectedItem.IsAnimation}"/>
                <CheckBox Grid.Row="8" Grid.Column="1" Content="Allow Dist Read"  IsChecked="{Binding SelectedItem.IsAllowDistRead}"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- ══ Properties Card ══ -->
          <Border Classes="card">
            <StackPanel Spacing="6">
              <TextBlock Classes="heading" Text="Properties"/>
              <Grid ColumnDefinitions="Auto,*,16,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                    ColumnSpacing="8" RowSpacing="5">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Ground Speed" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Classes="field" Text="{Binding SelectedItem.Speed}"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Classes="label" Text="Minimap Color" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Spacing="6">
                  <TextBox Classes="field" Text="{Binding SelectedItem.MinimapColor}" MinWidth="50"/>
                  <Border Width="24" Height="24" CornerRadius="4"
                          Background="{Binding SelectedItem.MinimapColorBrush}"
                          BorderBrush="#45475a" BorderThickness="1"
                          VerticalAlignment="Center" Cursor="Hand"
                          PointerPressed="OnMinimapSwatchClicked">
                    <FlyoutBase.AttachedFlyout>
                      <Flyout Placement="Bottom">
                        <StackPanel Spacing="6" Width="240">
                          <TextBlock Text="Tibia Minimap Palette" FontWeight="Bold" Foreground="#cdd6f4" FontSize="11"/>
                          <ItemsControl ItemsSource="{Binding MinimapPalette}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel/>
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:MinimapColorEntry">
                                <Border Width="14" Height="14" CornerRadius="2" Margin="1"
                                        Background="{Binding Brush}" Cursor="Hand"
                                        BorderBrush="#45475a" BorderThickness="0.5"
                                        PointerPressed="OnMinimapColorPicked"
                                        Tag="{Binding Index}"
                                        ToolTip.Tip="{Binding Index}"/>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Flyout>
                    </FlyoutBase.AttachedFlyout>
                  </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Light Level" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Classes="field" Text="{Binding SelectedItem.LightLevel}"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Classes="label" Text="Light Color" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="4" Classes="field" Text="{Binding SelectedItem.LightColor}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Trade As" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Classes="field" Text="{Binding SelectedItem.WareId}"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Classes="label" Text="Stack Order" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="4"
                          ItemsSource="{Binding StackOrderOptions}"
                          SelectedItem="{Binding SelectedItem.StackOrderValue}"
                          FontSize="12" MinHeight="28" Padding="6,3"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- ══ Animation Card ══ -->
          <Border Classes="card" BorderBrush="{Binding SelectedItem.HasMismatch, Converter={StaticResource MismatchBorderConverter}}"
                  BorderThickness="2">
            <StackPanel Spacing="6">
              <DockPanel>
                <TextBlock Classes="heading" Text="Animation" DockPanel.Dock="Left"/>
                <Border DockPanel.Dock="Right" IsVisible="{Binding SelectedItem.HasMismatch}"
                        Classes="mismatch-badge" VerticalAlignment="Top">
                  <TextBlock Text="MISMATCH" FontSize="10" FontWeight="Bold" Foreground="#1e1e2e"/>
                </Border>
              </DockPanel>

              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="DAT Phases" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding SelectedItem.DatAnimPhases}"
                           FontWeight="Bold" Foreground="#cba6f7" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Animate Always" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding SelectedItem.DatAnimateAlways}"
                           Foreground="#585b70" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding SelectedItem.MismatchDetail}"
                           Foreground="#f38ba8" FontSize="11" TextWrapping="Wrap"
                           IsVisible="{Binding SelectedItem.HasMismatch}"/>
              </Grid>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
