<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:local="clr-namespace:AssetsAndMapEditor.App"
        x:Class="AssetsAndMapEditor.App.WelcomeWindow"
        Title="Assets &amp; Map Editor"
        Width="640" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        SystemDecorations="BorderOnly">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#45475a"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#b4d0fb"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">

        <!-- ═══ Left Panel: Logo + Actions ═══ -->
        <Border Background="#181825" Padding="24,32">
            <DockPanel>
                <!-- Bottom: version -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0" FontSize="10"
                           Foreground="#585b70" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <StackPanel Spacing="16" VerticalAlignment="Center">
                    <!-- App title -->
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <i:Icon Value="fa-solid fa-map" FontSize="32" Foreground="#89b4fa"
                                HorizontalAlignment="Center"/>
                        <TextBlock Text="Assets &amp; Map Editor" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Foreground="#cdd6f4"/>
                        <TextBlock Text="Tibia Map Editor" FontSize="11"
                                   HorizontalAlignment="Center" Foreground="#585b70"/>
                    </StackPanel>

                    <Border Height="1" Background="#313244" Margin="0,8"/>

                    <!-- Action buttons -->
                    <Button x:Name="BtnNewSession" Classes="primary" HorizontalAlignment="Stretch"
                            Click="OnNewSessionClick">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-plus" FontSize="12"/>
                            <TextBlock Text="New Session"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnOpenFiles" HorizontalAlignment="Stretch"
                            Click="OnOpenFilesClick">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-folder-open" FontSize="12"/>
                            <TextBlock Text="Open Files..."/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Right Panel: Recent Sessions ═══ -->
        <Border Grid.Column="1" Padding="20,24">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Recent Sessions" FontSize="14"
                           FontWeight="SemiBold" Foreground="#cdd6f4" Margin="0,0,0,12"/>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8" IsVisible="False">
                    <i:Icon Value="fa-solid fa-clock-rotate-left" FontSize="28" Foreground="#45475a"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="No recent sessions" FontSize="12" Foreground="#585b70"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Start a new session or open files to begin" FontSize="11"
                               Foreground="#45475a" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Session list -->
                <ScrollViewer x:Name="SessionScroller">
                    <ItemsControl x:Name="SessionList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryDisplayItem">
                                <Button Margin="0,0,0,6" Padding="12,10" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Tag="{Binding}"
                                        Click="OnHistoryEntryClick">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                       FontWeight="SemiBold" Foreground="#cdd6f4"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Detail}" FontSize="10"
                                                       Foreground="#585b70" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TimeAgo}" FontSize="10"
                                                   Foreground="#585b70" VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
