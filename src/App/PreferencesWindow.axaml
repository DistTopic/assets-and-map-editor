<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        x:Class="AssetsAndMapEditor.App.PreferencesWindow"
        Title="Preferences"
        Width="380" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e"
        SystemDecorations="BorderOnly">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#45475a"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#b4d0fb"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </Window.Styles>

    <Border Background="#1e1e2e" Padding="24">
        <DockPanel>
            <!-- Title -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <i:Icon Value="fa-solid fa-gear" FontSize="18" Foreground="#89b4fa"/>
                <TextBlock Text="Preferences" FontSize="18" FontWeight="SemiBold" Foreground="#cdd6f4"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                <Button Content="Cancel" Click="OnCancel"/>
                <Button Classes="primary" Content="Save" Click="OnSave"/>
            </StackPanel>

            <!-- Settings -->
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                    <TextBlock Text="Items per page" VerticalAlignment="Center" FontSize="13"/>
                    <NumericUpDown Grid.Column="1" x:Name="ItemsPerPageInput"
                                   Minimum="10" Maximum="1000" Increment="10"
                                   Width="120" FontSize="13" FormatString="0"/>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
