<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:local="clr-namespace:AssetsAndMapEditor.App"
        x:Class="AssetsAndMapEditor.App.DatOtbSyncWindow"
        x:DataType="local:DatOtbSyncWindow"
        Title="DAT ↔ OTB Property Compare"
        Width="980" Height="680"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="780" MinHeight="500"
        Background="#1e1e2e">

  <Window.Styles>
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#89b4fa"/>
      <Setter Property="Foreground" Value="#1e1e2e"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <!-- Direction toggle buttons -->
    <Style Selector="Button.dirBtn">
      <Setter Property="Padding" Value="10,3"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontFamily" Value="Cascadia Code,JetBrains Mono,Consolas,monospace"/>
      <Setter Property="MinWidth" Value="80"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Styles>

  <DockPanel>

    <!-- ══ Bottom bar ════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom" Background="#181825" Padding="16,10" BorderBrush="#313244" BorderThickness="0,1,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <Button x:Name="ApplyButton" Content="Apply Changes" Classes="accent" Click="ApplyButton_Click" IsEnabled="False"/>
          <Button Content="Cancel" Click="CancelButton_Click" Padding="16,8"/>
        </StackPanel>
        <TextBlock x:Name="SummaryLabel" Foreground="#a6adc8" VerticalAlignment="Center" FontSize="13"/>
      </DockPanel>
    </Border>

    <!-- ══ Main content ══════════════════════════════════════════ -->
    <Grid ColumnDefinitions="260,1,*" Margin="0">

      <!-- ── Left: Item list ──────────────────────────────────── -->
      <DockPanel Grid.Column="0" Background="#181825">

        <!-- Counter header -->
        <Border DockPanel.Dock="Top" Padding="12,10" Background="#1e1e2e" BorderBrush="#313244" BorderThickness="0,0,0,1">
          <StackPanel Spacing="6">
            <TextBlock Text="DAT ↔ OTB Compare" FontWeight="Bold" Foreground="#cdd6f4" FontSize="14"/>
            <TextBlock x:Name="ItemCountLabel" Foreground="#f9e2af" FontSize="12"/>
          </StackPanel>
        </Border>

        <!-- Item list with sprites -->
        <ListBox x:Name="ItemListBox"
                 SelectionMode="Single"
                 Background="Transparent"
                 SelectionChanged="ItemListBox_SelectionChanged">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="local:DivergentItemVm">
              <Border Padding="8,6" Background="Transparent" CornerRadius="4">
                <Grid ColumnDefinitions="40,*,Auto" RowDefinitions="Auto,Auto">
                  <!-- Sprite -->
                  <Border Grid.Column="0" Grid.RowSpan="2"
                          Width="36" Height="36" CornerRadius="4"
                          Background="#313244" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Image Source="{Binding Sprite}"
                           Width="32" Height="32"
                           RenderOptions.BitmapInterpolationMode="None"
                           Stretch="Uniform"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  </Border>
                  <!-- IDs -->
                  <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding ServerIdText}" Foreground="#f38ba8" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="↔" Foreground="#585b70" FontSize="12"/>
                    <TextBlock Text="{Binding ClientIdText}" Foreground="#89b4fa" FontSize="12" FontWeight="SemiBold"/>
                  </StackPanel>
                  <!-- Diff count + name -->
                  <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                    <TextBlock Text="{Binding DiffCountText}" Foreground="#fab387" FontSize="11"/>
                    <TextBlock Text="{Binding Name}" Foreground="#6c7086" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="110"/>
                  </StackPanel>
                  <!-- Direction indicator -->
                  <Border Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock Text="{Binding DirectionIndicator}" FontSize="13" Foreground="{Binding IndicatorColor}" VerticalAlignment="Center"/>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <!-- Splitter -->
      <Border Grid.Column="1" Background="#313244"/>

      <!-- ── Right: Property detail ───────────────────────────── -->
      <DockPanel Grid.Column="2" Background="#1e1e2e">

        <!-- Item header with large sprite -->
        <Border DockPanel.Dock="Top" Padding="16,12" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <!-- Large sprite -->
            <Border Grid.Column="0" Width="64" Height="64" CornerRadius="6"
                    Background="#313244" Margin="0,0,16,0" VerticalAlignment="Center">
              <Image x:Name="DetailSprite"
                     Width="56" Height="56"
                     RenderOptions.BitmapInterpolationMode="None"
                     Stretch="Uniform"
                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
            <!-- Item info -->
            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="SID" Foreground="#585b70" FontSize="11"/>
                  <TextBlock x:Name="ServerIdLabel" FontWeight="Bold" Foreground="#f38ba8" FontSize="18"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="CID" Foreground="#585b70" FontSize="11"/>
                  <TextBlock x:Name="ClientIdLabel" FontWeight="Bold" Foreground="#89b4fa" FontSize="18"/>
                </StackPanel>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="ItemNameLabel" Foreground="#a6e3a1" FontSize="13"/>
                <TextBlock x:Name="GroupLabel" Foreground="#585b70" FontSize="12" FontStyle="Italic"/>
              </StackPanel>
              <TextBlock x:Name="DiffCountLabel" Foreground="#fab387" FontSize="12"/>
            </StackPanel>
            <!-- Batch actions -->
            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
              <Button Content="All → use OTB" Click="AllUseOtb_Click" Padding="10,4" FontSize="12" HorizontalAlignment="Stretch"/>
              <Button Content="All → use DAT" Click="AllUseDat_Click" Padding="10,4" FontSize="12" HorizontalAlignment="Stretch"/>
              <Button Content="All → skip" Click="AllSkip_Click" Padding="10,4" FontSize="12" HorizontalAlignment="Stretch"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Legend -->
        <Border DockPanel.Dock="Top" Padding="16,8,16,0">
          <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock Foreground="#585b70" FontSize="11" Text="Click a value to choose it. The highlighted value will be applied."/>
          </StackPanel>
        </Border>

        <!-- Properties table -->
        <Border Margin="16,8" CornerRadius="6" BorderBrush="#313244" BorderThickness="1" ClipToBounds="True">
          <DockPanel>
            <!-- Table header -->
            <Border DockPanel.Dock="Top" Background="#313244" Padding="12,8">
              <Grid ColumnDefinitions="*,180,30,180">
                <TextBlock Grid.Column="0" Text="Property" FontWeight="Bold" Foreground="#a6adc8" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="OTB Value" FontWeight="Bold" Foreground="#f38ba8" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="↔" Foreground="#585b70" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="DAT Value" FontWeight="Bold" Foreground="#89b4fa" FontSize="12" HorizontalAlignment="Center"/>
              </Grid>
            </Border>
            <!-- Property rows -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <ItemsControl x:Name="PropertiesList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="local:PropertyDifference">
                    <Border Padding="12,6" BorderBrush="#313244" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="*,180,30,180">
                        <TextBlock Grid.Column="0" Text="{Binding PropertyName}"
                                   Foreground="#cdd6f4" FontSize="13" VerticalAlignment="Center"/>
                        <!-- OTB value button -->
                        <Button Grid.Column="1" Classes="dirBtn"
                                Background="{Binding OtbBackground}"
                                Foreground="{Binding OtbForeground}"
                                Tag="{Binding}"
                                Click="OtbValueBtn_Click"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="14" Height="14" CornerRadius="3"
                                    Background="{Binding OtbColorSwatch}"
                                    BorderBrush="#585b70" BorderThickness="1"
                                    IsVisible="{Binding IsColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OtbValue}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                        <!-- Direction arrow -->
                        <TextBlock Grid.Column="2" Text="{Binding DirectionArrow}"
                                   Foreground="{Binding ArrowColor}" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        <!-- DAT value button -->
                        <Button Grid.Column="3" Classes="dirBtn"
                                Background="{Binding DatBackground}"
                                Foreground="{Binding DatForeground}"
                                Tag="{Binding}"
                                Click="DatValueBtn_Click"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Width="14" Height="14" CornerRadius="3"
                                    Background="{Binding DatColorSwatch}"
                                    BorderBrush="#585b70" BorderThickness="1"
                                    IsVisible="{Binding IsColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DatValue}" VerticalAlignment="Center"/>
                          </StackPanel>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>

      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
